# uatchit — environment template (safe to commit)
# Copy to .env and fill in real values:  cp .env.example .env
# The web app validates these on boot via apps/web/src/lib/env.ts (Zod).

# ─────────────────────────────────────────────────────────────
# App runtime — read by the Next.js app + cron worker
# ─────────────────────────────────────────────────────────────

# --- Database (Postgres 17) ---
# Local dev:  postgres://uatchit:uatchit@127.0.0.1:5432/uatchit
# In Docker:  postgres://uatchit:<password>@db:5432/uatchit
DATABASE_URL=postgres://uatchit:uatchit@127.0.0.1:5432/uatchit

# --- Auth.js (NextAuth v5) ---
# Generate a secret:  openssl rand -base64 32
AUTH_SECRET=replace_with_32+_char_random_string
# Set to "true" when running behind a proxy/tunnel (production)
AUTH_TRUST_HOST=true
# Canonical public URL of the app. REQUIRED in production behind a proxy/tunnel,
# otherwise magic-link and callback URLs derive from the server's bind address
# (e.g. 0.0.0.0:3000) and break. Omit for local dev.
# AUTH_URL=https://app.uatchit.com

# --- Email (Resend) — magic-link + OTP login + change notifications ---
# Get a key: https://resend.com/api-keys  (both vars use the same key)
AUTH_RESEND_KEY=re_your_resend_key_here
RESEND_API_KEY=re_your_resend_key_here
# Sender. For local dev "onboarding@resend.dev" works but only delivers to
# your own Resend account email. In production use a verified domain sender.
EMAIL_FROM=uatchit <onboarding@resend.dev>

# --- LLM provider — AI/ML API (OpenAI-compatible gateway) ---
# Get a key: https://aimlapi.com/app/keys
AIMLAPI_KEY=your_aimlapi_key_here
LLM_BASE_URL=https://api.aimlapi.com/v1
# Single-call paths: schema inference, field extraction, change narration
LLM_MODEL=google/gemini-3-1-flash-lite
# Multi-turn chat agent (Pro — Flash-Lite breaks on follow-up tool calls here)
LLM_CHAT_MODEL=google/gemini-3-1-pro-preview

# --- Bright Data — page fetching (Web Unlocker) ---
# Get a key: https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=your_brightdata_api_key_here
# Zone names — auto-created on first billing setup (check your dashboard)
BRIGHTDATA_ZONE_UNLOCKER=mcp_unlocker
BRIGHTDATA_ZONE_BROWSER=mcp_browser

# --- Cron orchestrator auth ---
# Shared secret the cron worker sends as the x-cron-secret header
# Generate:  openssl rand -hex 32
CRON_SECRET=replace_with_32+_char_random_string

# --- Public URLs ---
# Local dev defaults to http://localhost:3000 for both.
# Production:
#   NEXT_PUBLIC_APP_URL=https://app.uatchit.com
#   NEXT_PUBLIC_MARKETING_URL=https://uatchit.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Optional — pre-built Bright Data scraper dataset IDs
# When set, URLs matching the platform bypass LLM inference and use BD's
# canonical schema (faster + deterministic). Unset = fall through to the LLM.
# Browse IDs at https://brightdata.com/cp/scrapers/browse
# ─────────────────────────────────────────────────────────────
# BRIGHTDATA_DATASET_LINKEDIN_PROFILE=
# BRIGHTDATA_DATASET_LINKEDIN_COMPANY=
# BRIGHTDATA_DATASET_LINKEDIN_JOB=
# BRIGHTDATA_DATASET_AMAZON_PRODUCT=
# BRIGHTDATA_DATASET_CRUNCHBASE_COMPANY=
# BRIGHTDATA_DATASET_YAHOO_FINANCE=
# BRIGHTDATA_DATASET_X_POST=
# BRIGHTDATA_DATASET_YOUTUBE_VIDEO=

# ─────────────────────────────────────────────────────────────
# Extension (Plasmo) — build-time only, set when packaging for production
# ─────────────────────────────────────────────────────────────
# PLASMO_PUBLIC_APP_URL=https://app.uatchit.com

# ─────────────────────────────────────────────────────────────
# Deployment tooling — NOT read by the app. Only needed if you use the
# deploy scripts (Cloudflare Tunnel / DNS, Vultr API). Optional.
# ─────────────────────────────────────────────────────────────
# VULTR_API_KEY=your_vultr_api_key_here
# CLOUDFLARE_EMAIL=your_cf_email@example.com
# CLOUDFLARE_API_KEY=your_cf_global_api_key_here
# CLOUDFLARE_ACCOUNT_ID=your_cf_account_id_here
# CLOUDFLARE_ZONE_ID_UATCHIT=your_uatchit_zone_id_here
