{
  "name": "@uatchit/extension",
  "displayName": "uatchit",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@plasmohq/storage": "^1.13.0",
    "@plasmohq/messaging": "^0.7.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.0.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  },
  "manifest": {
    "permissions": ["sidePanel", "contextMenus", "storage", "activeTab", "cookies", "scripting", "alarms", "tabs"],
    "host_permissions": ["<all_urls>", "http://localhost:3000/*", "https://app.uatchit.com/*"],
    "side_panel": { "default_path": "sidepanel.html" },
    "action": { "default_title": "uatchit" }
  }
}
